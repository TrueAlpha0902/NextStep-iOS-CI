{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nextstep.local/schemas/ai/paper-search-v1.json",
  "title": "NextStep Paper Search Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "requestID", "query", "searchedAt", "connectors", "results", "warnings"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "requestID": { "$ref": "#/$defs/uuid" },
    "query": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "searchedAt": { "type": "string", "format": "date-time" },
    "connectors": { "type": "array", "minItems": 1, "maxItems": 20, "uniqueItems": true, "items": { "enum": ["crossref", "openalex", "arxiv", "pubmed", "pmc", "unpaywall", "doi", "manual"] } },
    "results": {
      "type": "array", "maxItems": 200,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["candidateID", "title", "authors", "publicationYear", "venue", "doi", "officialURL", "legalAccessLinks", "sourceType", "peerReviewStatus", "isPreprint", "recommendationReasons", "relatedGoalIDs", "providerRecords", "verificationStatus"],
        "properties": {
          "candidateID": { "$ref": "#/$defs/uuid" },
          "title": { "type": "string", "minLength": 1, "maxLength": 2000 },
          "authors": { "type": "array", "minItems": 1, "maxItems": 500, "items": { "type": "string", "minLength": 1, "maxLength": 300 } },
          "publicationYear": { "type": ["integer", "null"], "minimum": 1000, "maximum": 3000 },
          "venue": { "type": ["string", "null"], "minLength": 1, "maxLength": 1000 },
          "doi": { "type": ["string", "null"], "pattern": "^10\\.[0-9]{4,9}/[-._;()/:A-Za-z0-9]+$", "maxLength": 300 },
          "officialURL": { "type": ["string", "null"], "format": "uri", "maxLength": 2048 },
          "legalAccessLinks": {
            "type": "array", "maxItems": 20,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["url", "accessType", "host", "license"],
              "properties": {
                "url": { "type": "string", "format": "uri", "maxLength": 2048 },
                "accessType": { "enum": ["openFullText", "repositoryFullText", "authorManuscript", "abstract", "metadata", "unknown"] },
                "host": { "type": "string", "minLength": 1, "maxLength": 255 },
                "license": { "type": ["string", "null"], "maxLength": 300 }
              }
            }
          },
          "sourceType": { "enum": ["journalArticle", "conferencePaper", "preprint", "workingPaper", "bookChapter", "report", "thesis", "other"] },
          "peerReviewStatus": { "enum": ["verifiedPeerReviewed", "notPeerReviewed", "unknown", "conflicting"] },
          "isPreprint": { "type": "boolean" },
          "recommendationReasons": { "type": "array", "maxItems": 10, "items": { "type": "string", "minLength": 1, "maxLength": 500 } },
          "relatedGoalIDs": { "type": "array", "maxItems": 20, "uniqueItems": true, "items": { "$ref": "#/$defs/uuid" } },
          "providerRecords": {
            "type": "array", "minItems": 1, "maxItems": 20,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["connector", "recordID", "retrievedAt"],
              "properties": {
                "connector": { "type": "string", "minLength": 1, "maxLength": 50 },
                "recordID": { "type": "string", "minLength": 1, "maxLength": 500 },
                "retrievedAt": { "type": "string", "format": "date-time" }
              }
            }
          },
          "verificationStatus": { "enum": ["unverified", "singleSource", "crossChecked", "conflicting"] }
        }
      }
    },
    "warnings": { "type": "array", "maxItems": 100, "items": { "type": "string", "minLength": 1, "maxLength": 500 } }
  },
  "$defs": { "uuid": { "type": "string", "format": "uuid" } }
}
