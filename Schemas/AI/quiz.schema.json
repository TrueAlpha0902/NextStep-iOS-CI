{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nextstep.local/schemas/ai/quiz-v1.json",
  "title": "NextStep Quiz Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "requestID", "quizID", "packageID", "learningObjectiveIDs", "passThreshold", "items", "confidence", "unresolvedIssues"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "requestID": { "$ref": "#/$defs/uuid" },
    "quizID": { "$ref": "#/$defs/uuid" },
    "packageID": { "$ref": "#/$defs/uuid" },
    "learningObjectiveIDs": { "type": "array", "minItems": 1, "maxItems": 20, "uniqueItems": true, "items": { "$ref": "#/$defs/uuid" } },
    "passThreshold": { "type": "number", "minimum": 0, "maximum": 1 },
    "items": {
      "type": "array", "minItems": 1, "maxItems": 30,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["itemID", "kind", "prompt", "options", "correctAnswer", "rationale", "evidenceLinkIDs", "objectiveIDs", "difficulty"],
        "properties": {
          "itemID": { "$ref": "#/$defs/uuid" },
          "kind": { "enum": ["singleChoice", "multipleChoice", "shortAnswer", "application"] },
          "prompt": { "type": "string", "minLength": 1, "maxLength": 2000 },
          "options": { "type": "array", "maxItems": 10, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
          "correctAnswer": { "type": "string", "minLength": 1, "maxLength": 2000 },
          "rationale": { "type": "string", "minLength": 1, "maxLength": 3000 },
          "evidenceLinkIDs": { "type": "array", "minItems": 1, "maxItems": 20, "uniqueItems": true, "items": { "$ref": "#/$defs/uuid" } },
          "objectiveIDs": { "type": "array", "minItems": 1, "maxItems": 20, "uniqueItems": true, "items": { "$ref": "#/$defs/uuid" } },
          "difficulty": { "enum": ["recall", "understand", "apply", "analyze"] }
        }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "unresolvedIssues": { "type": "array", "maxItems": 50, "items": { "type": "string", "minLength": 1, "maxLength": 1000 } }
  },
  "$defs": { "uuid": { "type": "string", "format": "uuid" } }
}
