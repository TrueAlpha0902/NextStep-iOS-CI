    "Review later is safe: this class will remain in Needs Review after relaunch." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Review later is safe: this class will remain in Needs Review after relaunch." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "稍後檢視是安全的：重新啟動後，此課堂仍會維持「需要檢視」狀態。" } } } },
