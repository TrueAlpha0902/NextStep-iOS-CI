    "Ending class stops new class markers. Your note stays available and editable." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Ending class stops new class markers. Your note stays available and editable." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "結束課堂後將停止新增課堂標記；筆記仍可使用及編輯。" } } } },
