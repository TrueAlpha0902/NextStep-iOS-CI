    "This completed class is read-only here." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This completed class is read-only here." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "此已完成的課堂在此為唯讀。" } } } },
