    "Shorten the one-line class summary before finishing review." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Shorten the one-line class summary before finishing review." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "請縮短一行課堂摘要，再完成檢視。" } } } },
    "Add a candidate name before marking it ready for later confirmation." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Add a candidate name before marking it ready for later confirmation." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "將候選項目標記為「準備稍後確認」前，請先加入名稱。" } } } },
    "Choose whether the candidate date is unknown, estimated, or confirmed." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Choose whether the candidate date is unknown, estimated, or confirmed." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "請選擇候選日期為未知、估計或已確認。" } } } },
    "Add a reason before rejecting this marker." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Add a reason before rejecting this marker." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "拒絕此標記前，請先加入原因。" } } } },
    "Shorten the rejection reason before finishing review." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Shorten the rejection reason before finishing review." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "請縮短拒絕原因，再完成檢視。" } } } },
    "Check the selected marker's fields before finishing review." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Check the selected marker's fields before finishing review." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "請檢查所選標記的欄位，再完成檢視。" } } } },
    "That decision is not available for the marker's current state." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "That decision is not available for the marker's current state." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "目前標記狀態不支援此決定。" } } } },
    "This review is frozen for a safe retry and can no longer be edited." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This review is frozen for a safe retry and can no longer be edited." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "此檢視已凍結以供安全重試，無法再編輯。" } } } },
    "The saved class markers changed. Close and reopen this review." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The saved class markers changed. Close and reopen this review." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "已儲存的課堂標記已變更。請關閉並重新開啟此檢視。" } } } },
    "This class no longer needs a wrap-up." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This class no longer needs a wrap-up." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "此課堂不再需要課後整理。" } } } },
