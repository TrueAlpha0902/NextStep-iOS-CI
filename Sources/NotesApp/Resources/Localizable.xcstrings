    "Only the class status failed to save. Retrying reuses the same end request." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Only the class status failed to save. Retrying reuses the same end request." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "只有課堂狀態儲存失敗；重試會沿用相同的結束請求。" } } } },
    "The saved class status changed or this request is no longer valid. Close this sheet and review the current session." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The saved class status changed or this request is no longer valid. Close this sheet and review the current session." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "已儲存的課堂狀態已變更，或此請求已失效。請關閉此畫面並檢視目前課堂。" } } } },
