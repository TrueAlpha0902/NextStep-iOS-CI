    "This candidate changed elsewhere. The newer saved version was not overwritten." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This candidate changed elsewhere. The newer saved version was not overwritten." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "此候選項目已在其他位置變更；較新的已儲存版本未被覆寫。" } } } },
    "This candidate is no longer in the saved class." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This candidate is no longer in the saved class." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "此候選項目已不在已儲存的課堂中。" } } } },
    "The review is ready, but academic data could not be saved." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The review is ready, but academic data could not be saved." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "檢視內容已準備好，但無法儲存學術資料。" } } } },
    "Choose a valid date in the course time zone or mark the date unknown." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Choose a valid date in the course time zone or mark the date unknown." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "請在課程時區選擇有效日期，或將日期標記為未知。" } } } },
    "Captured source" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Captured source" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "擷取時的來源" } } } },
    "Quick capture" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Quick capture" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "快速擷取" } } } },
    "Checking the saved paragraph" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Checking the saved paragraph" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "正在檢查已儲存的段落" } } } },
    "Current paragraph (changed)" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Current paragraph (changed)" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "目前段落（已變更）" } } } },
    "NextStep will not guess or move this marker to different text." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "NextStep will not guess or move this marker to different text." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "NextStep 不會猜測來源，也不會把此標記移到其他文字。" } } } },
    "Retry source check" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Retry source check" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "重新檢查來源" } } } },
    "Finish or discard the pending class marker first." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Finish or discard the pending class marker first." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "請先完成或捨棄待處理的課堂標記。" } } } },
    "Stop and save the audio recording before ending class." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Stop and save the audio recording before ending class." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "結束課堂前，請先停止並儲存錄音。" } } } },
    "Wait for academic data to become available." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Wait for academic data to become available." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "請等待學術資料恢復可用。" } } } },
    "Wait for the library change to finish." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Wait for the library change to finish." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "請等待資料庫變更完成。" } } } },
    "The class status changed while the end confirmation was open. Review the current saved session." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The class status changed while the end confirmation was open. Review the current saved session." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "結束確認畫面開啟期間，課堂狀態已變更。請檢視目前已儲存的課堂。" } } } },
    "The class status changed while review was open. No review decision was overwritten." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The class status changed while review was open. No review decision was overwritten." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "檢視畫面開啟期間，課堂狀態已變更。沒有任何檢視決定被覆寫。" } } } },
    "This class is no longer available for candidate review." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This class is no longer available for candidate review." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "此課堂已無法進行候選項目檢視。" } } } },
    "Saving this note before class review" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Saving this note before class review" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "正在課堂檢視前儲存此筆記" } } } },
    "The note could not be saved safely. Class status was not changed. Retry the note save before ending class." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The note could not be saved safely. Class status was not changed. Retry the note save before ending class." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "無法安全地儲存筆記，課堂狀態未變更。結束課堂前，請重試儲存筆記。" } } } },
    "The class changed while its note was being saved. Review the current status and try again." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The class changed while its note was being saved. Review the current status and try again." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "儲存筆記期間，課堂已變更。請檢視目前狀態後再試一次。" } } } },
    "The note could not be saved safely. Candidate review was not opened. Retry the note save first." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The note could not be saved safely. Candidate review was not opened. Retry the note save first." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "無法安全地儲存筆記，因此未開啟候選項目檢視。請先重試儲存筆記。" } } } },
    "The note could not be saved safely. The class review was not opened. Retry the note save first." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The note could not be saved safely. The class review was not opened. Retry the note save first." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "無法安全地儲存筆記，因此未開啟課堂檢視。請先重試儲存筆記。" } } } },
    "This class changed elsewhere. No class status was overwritten." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This class changed elsewhere. No class status was overwritten." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "此課堂已在其他位置變更，沒有任何課堂狀態被覆寫。" } } } },
    "The note is safe, but the class status could not be saved." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The note is safe, but the class status could not be saved." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "筆記已安全儲存，但無法儲存課堂狀態。" } } } },
    "This class is not ready for review. Reopen the saved session and try again." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "This class is not ready for review. Reopen the saved session and try again." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "此課堂尚未準備好進行檢視。請重新開啟已儲存的課堂後再試一次。" } } } },
    "End class" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "End class" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "結束課堂" } } } },
    "Review class" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Review class" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "檢視課堂" } } } },
    "Saved on this iPad" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Saved on this iPad" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "已儲存在此 iPad" } } } },
