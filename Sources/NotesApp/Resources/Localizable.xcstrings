    "Candidates" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Candidates" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "候選項目" } } } },
    "Assignment and exam markers from this class will appear here." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Assignment and exam markers from this class will appear here." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "此課堂的作業與考試標記會顯示在這裡。" } } } },
    "Review its saved source and decide what should happen next." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Review its saved source and decide what should happen next." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "檢視已儲存的來源，並決定下一步。" } } } },
