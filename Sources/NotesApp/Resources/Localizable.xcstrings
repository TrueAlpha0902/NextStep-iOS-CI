    "Retrying reuses the exact same fields, audit identifiers, and review time." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Retrying reuses the exact same fields, audit identifiers, and review time." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "重試會沿用完全相同的欄位、稽核識別碼與檢視時間。" } } } },
