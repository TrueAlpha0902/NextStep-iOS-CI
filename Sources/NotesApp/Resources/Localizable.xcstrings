    "Ready for later confirmation records a reviewed candidate only. It does not create a formal assignment, exam, notification, or hard deadline." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Ready for later confirmation records a reviewed candidate only. It does not create a formal assignment, exam, notification, or hard deadline." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "「準備稍後確認」只會記錄已檢視的候選項目，不會建立正式作業、考試、通知或硬性期限。" } } } },
    "Candidate" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Candidate" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "候選項目" } } } },
