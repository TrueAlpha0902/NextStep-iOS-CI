    "The saved date cannot be represented in this course time zone. Choose a new date or mark it unknown before saving." : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The saved date cannot be represented in this course time zone. Choose a new date or mark it unknown before saving." } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "無法在此課程時區表示已儲存的日期。儲存前請選擇新日期，或將日期標記為未知。" } } } },
